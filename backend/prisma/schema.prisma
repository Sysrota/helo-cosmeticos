generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                Int      @id @default(autoincrement())

  title             String
  subtitle          String   @default("")
  meta_description  String   @default("")
  description       String   @default("")

  keywords          String @default("")

  price             Float

  category          String

  image_url         String   @default("")

  dicas_uso         String   @default("")
  o_que_vai_sentir  String   @default("")
  destaques         String   @default("")
  composicao        String   @default("")
  indicacoes        String   @default("")
  restricoes        String   @default("")
  faq               String   @default("")

  is_active         Boolean  @default(true)
  is_featured       Boolean  @default(false)
  em_divulgacao     Boolean  @default(false)
  free_shipping     Boolean  @default(false)
  sort_order        Int      @default(0)


  weight Float @default(0)

  height Float @default(0)

  width Float @default(0)

  length Float @default(0)

  lot_quantity                       Int   @default(0)
  production_cost_total              Float @default(0)
  packaging_cost_total               Float @default(0)
  labels_cost_total                  Float @default(0)
  shipping_materials_cost_total      Float @default(0)
  factory_freight_cost_total         Float @default(0)
  payment_fee_percent                Float @default(0)
  sales_tax_percent                  Float @default(0)
  company_shipping_cost_avg          Float @default(0)
  customer_acquisition_cost_avg      Float @default(0)
  desired_profit_margin_percent      Float @default(0)

  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  images            ProductImage[]

  order_items OrderItem[]

  @@map("products")
}

model ProductImage {
  id          Int      @id @default(autoincrement())

  product_id  Int

  image_url   String

  sort_order  Int      @default(0)

  created_at  DateTime @default(now())

  product     Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model User {
  id            Int       @id @default(autoincrement())

  name          String

  email         String    @unique

  password      String

  role          String    @default("admin")

  is_active     Boolean   @default(true)

  created_at    DateTime  @default(now())

  updated_at    DateTime  @updatedAt

  @@map("users")
}

model Contact {
  id Int @id @default(autoincrement())

  name String?

  phone String @unique

  email String?

  cpf String?

  birth_date DateTime?

  city String?
  state String?

  notes String? @db.Text

  lead_status String @default("novo")

  total_spent Float @default(0)

  last_order_at DateTime?

  blocked_ai Boolean @default(false)

  priority Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  conversations Conversation[]

  addresses ContactAddress[]

  orders Order[]

  coupon_redemptions CouponRedemption[]

  @@map("contacts")
}

model Conversation {
  id              Int       @id @default(autoincrement())

  contact_id      Int

  status          String    @default("open")

  unread_count    Int @default(0)

  sector          String?

  last_message    String?

  last_message_at DateTime?

  ai_stage        String?
  ai_summary      String?
  cart_json       Json?
  customer_name   String?
  customer_city   String?
  customer_state  String?
  checkout_url    String?
  last_product_id Int?

  checkout_token String?
  last_order_id Int?

  created_at      DateTime  @default(now())

  updated_at      DateTime  @updatedAt

  contact         Contact   @relation(fields: [contact_id], references: [id])

  messages        Message[]

  @@map("conversations")
}

model Message {
  id                Int       @id @default(autoincrement())

  conversation_id   Int

  sender_type       String

  content           String

  type              String    @default("text")

  media_url         String?

  is_read           Boolean   @default(false)

  created_at        DateTime  @default(now())

  conversation      Conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)

  @@map("messages")
}

model StoreConfig {
  id Int @id @default(1)

  payment_methods Json?

  shipping_methods Json?

  shipping_info String @default("")

  free_shipping_minimum Float @default(99)

  moto_uber_enabled Boolean @default(true)

  pix_discount_percent Float @default(10)

  card_interest_free_installments Int @default(3)

  card_max_installments Int @default(12)

  show_secure_purchase Boolean @default(true)

  business_hours String @default("")

  exchange_policy String @default("")

  ai_rules String @default("")

  manager_phone_1            String?
  manager_phone_2            String?
  manager_1_window_opened_at DateTime?
  manager_2_window_opened_at DateTime?
  manager_1_last_ping_at     DateTime?
  manager_2_last_ping_at     DateTime?

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  @@map("store_config")
}

model ManagerNotification {
  id         Int       @id @default(autoincrement())
  phone      String
  content    String    @db.Text
  sent_at    DateTime?
  created_at DateTime  @default(now())

  @@map("manager_notifications")
}

model ContactAddress {
  id Int @id @default(autoincrement())

  contact_id Int

  cep String

  street String?
  number String?
  complement String?
  district String?
  city String?
  state String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  contact Contact@relation(fields: [contact_id],references: [id])

  @@map("contact_addresses")
}

model Order {
  id Int @id @default(autoincrement())

  order_number String? @unique

  contact_id Int

  coupon_id Int?

  coupon_code String?

  status String @default("pending")

  subtotal Float @default(0)

  shipping Float @default(0)

  discount Float @default(0)

  coupon_discount Float @default(0)

  payment_discount Float @default(0)

  total Float @default(0)

  paid_at DateTime?

  payment_method String?
  payment_status String? @default("pending")
  pix_code String?
  pix_qrcode String?

  boleto_url     String?
  boleto_barcode String?

  mercado_pago_payment_id String?

  pending_email_sent_at DateTime?

  confirmation_email_sent_at DateTime?

  notes String?

  shipping_method String?

  shipping_price Float @default(0)

  shipping_deadline String?

  melhor_envio_service_id Int?

  melhor_envio_order_id String?

  melhor_envio_protocol String?

  melhor_envio_print_url String?

  tracking_code String?

  tracking_url String?

  shipping_status String?

  shipping_status_updated_at DateTime?

  shipping_events Json?

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  contact Contact@relation(fields: [contact_id], references: [id])

  coupon Coupon? @relation(fields: [coupon_id], references: [id])

  items OrderItem[]

  status_emails OrderStatusEmail[]

  customer_notifications OrderCustomerNotification[]

  coupon_redemptions CouponRedemption[]

  shipping_events_list OrderShippingEvent[]

  @@map("orders")
}

model OrderShippingEvent {
  id Int @id @default(autoincrement())

  order_id Int

  event String

  status String?

  title String

  description String?

  location String?

  tracking_code String?

  tracking_url String?

  occurred_at DateTime

  payload Json?

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@unique([order_id, event, occurred_at])
  @@map("order_shipping_events")
}

model Coupon {
  id Int @id @default(autoincrement())

  code String @unique

  name String

  partner_name String

  partner_email String?

  discount_type String

  discount_value Float @default(0)

  min_subtotal Float @default(0)

  max_discount Float?

  starts_at DateTime?

  ends_at DateTime?

  usage_limit Int?

  usage_limit_per_customer Int?

  allow_pix_discount Boolean @default(true)

  commission_percent Float @default(0)

  is_active Boolean @default(true)

  created_at DateTime @default(now())

  updated_at DateTime @updatedAt

  orders Order[]

  redemptions CouponRedemption[]

  @@map("coupons")
}

model CouponRedemption {
  id Int @id @default(autoincrement())

  coupon_id Int

  order_id Int

  contact_id Int

  code String

  discount Float @default(0)

  subtotal Float @default(0)

  total Float @default(0)

  status String @default("pending")

  redeemed_at DateTime @default(now())

  coupon Coupon @relation(fields: [coupon_id], references: [id], onDelete: Cascade)

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  contact Contact @relation(fields: [contact_id], references: [id])

  @@unique([coupon_id, order_id])
  @@map("coupon_redemptions")
}

model OrderSequence {
  year Int @id

  last_number Int @default(0)

  updated_at DateTime @updatedAt

  @@map("order_sequences")
}

model OrderStatusEmail {
  id Int @id @default(autoincrement())

  order_id Int

  status String

  sent_at DateTime @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@unique([order_id, status])
  @@map("order_status_emails")
}

model OrderCustomerNotification {
  id Int @id @default(autoincrement())

  order_id Int

  channel String

  type String

  sent_at DateTime @default(now())

  order Order @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@unique([order_id, channel, type])
  @@map("order_customer_notifications")
}

model OrderItem {
  id Int @id @default(autoincrement())

  order_id Int

  product_id Int

  quantity Int @default(1)

  unit_price Float

  total Float

  created_at DateTime @default(now())

  order Order @relation(fields: [order_id], references: [id])

  product Product @relation(fields: [product_id], references: [id])

  @@map("order_items")
}
